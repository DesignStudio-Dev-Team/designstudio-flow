{
  "name": "designstudio-flow",
  "version": "1.1.9",
  "description": "Build your WordPress Page with Artisanal Content Blocks",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "release": "bash scripts/build-release.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:php": "vendor/bin/phpunit",
    "security-check": "php -d memory_limit=1G vendor/bin/phpcs --standard=phpcs.xml.dist --extensions=php --ignore=./node_modules/*,./vendor/*,./assets/*,./tests/* && npm audit",
    "prepare": "husky install"
  },
  "dependencies": {
    "lucide-vue-next": "^0.312.0",
    "pinia": "^2.1.7",
    "sortablejs": "^1.15.2",
    "vue": "^3.4.15",
    "vuedraggable": "^4.1.0"
  },
  "overrides": {
    "@vitejs/plugin-vue": {
      "vite": "$vite"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
